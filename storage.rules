rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function sizeOk() {
      return request.resource.size < 50 * 1024 * 1024;
    }

    function contentTypeOk() {
      return request.resource.contentType.matches('image/.*')
        || request.resource.contentType.matches('video/.*')
        || request.resource.contentType.matches('application/pdf')
        || request.resource.contentType.matches('application/octet-stream');
    }

    /* ---- avatars/uid/... and other folder/uid/... paths ---- */
    match /{folder}/{userId}/{allPaths=**} {
      allow read: if signedIn();
      // ✅ FIX: removed isSuspended() — cross-service firestore.get() in Storage
      // rules is unreliable and causes permission-denied on all writes
      allow write: if isSelf(userId) && sizeOk() && contentTypeOk();
    }

    /* ---- support screenshots (private) ---- */
    match /support-screenshots/{userId}/{allPaths=**} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId) && sizeOk() && contentTypeOk();
    }

    match /support_screenshots/{userId}/{allPaths=**} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId) && sizeOk() && contentTypeOk();
    }

    match /support/{userId}/{allPaths=**} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId) && sizeOk() && contentTypeOk();
    }

    /* ---- uid/... (direct uid paths) ---- */
    match /{userId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isSelf(userId) && sizeOk() && contentTypeOk();
    }

    /* ---- default deny ---- */
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
