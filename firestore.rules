rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    function profileDoc(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId));
    }

    function hasProfile(userId) {
      return exists(/databases/$(database)/documents/profiles/$(userId));
    }

    function isAdmin() {
      return signedIn() &&
        hasProfile(uid()) &&
        profileDoc(uid()).data.role == "admin";
    }

    // ✅ NEW: minors (age_group "teen" or "under_13") are hard-blocked from
    // reading is_nsfw content — enforced here at the rules layer, so no
    // client-side toggle or modified app build can bypass it. Accounts with
    // no age_group set (pre-existing users from before this field existed)
    // are treated as adults by this check — defaulting unknown accounts to
    // "minor" would lock out existing real adult users. A migration to
    // backfill age_group on old accounts should be run separately; this
    // function intentionally does not try to guess for missing data.
    function isMinor() {
      return signedIn() &&
        hasProfile(uid()) &&
        (profileDoc(uid()).data.age_group == "teen" ||
         profileDoc(uid()).data.age_group == "under_13");
    }

    function isCounterUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['like_count', 'comment_count', 'repost_count', 'save_count', 'share_count', 'view_count']);
    }

    function isPollVoteUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['poll', 'updated_at', 'updated_at_ts']);
    }

    match /profiles/{userId} {
      allow read, get, list: if signedIn();
      allow create: if isSelf(userId);
      // ✅ admin can update any profile (e.g. unsuspend); self can update unless suspended
      allow update: if (isSelf(userId) && resource.data.is_suspended != true) || isAdmin();
      allow delete: if isSelf(userId) || isAdmin();
    }

    match /follows/{followId} {
      allow read, get, list: if signedIn();
      allow create: if signedIn() && request.resource.data.follower_id == uid();
      allow update: if signedIn() && resource.data.follower_id == uid();
      allow delete: if signedIn() && resource.data.follower_id == uid();
    }

    match /notifications/{notifId} {
      allow read: if signedIn() && resource.data.receiver_id == uid();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.receiver_id == uid();
      allow delete: if signedIn() && resource.data.receiver_id == uid();
    }

    match /posts/{postId} {
      // ✅ NEW: minors can never read posts flagged is_nsfw == true.
      // This is a per-document read check — Firestore evaluates it on the
      // single-document get() and applies it as a query-time filter on
      // list/collection queries too (queries against a flagged-true field
      // a minor can't read simply omit those docs from results, they don't
      // error the whole query).
      allow read, get, list: if signedIn() &&
        (resource.data.is_nsfw != true || !isMinor());
      allow create: if signedIn();
      allow update: if signedIn() && (
        resource.data.user_id == uid() ||
        isAdmin() ||
        isCounterUpdate() ||
        isPollVoteUpdate()
      );
      allow delete: if signedIn() && (resource.data.user_id == uid() || isAdmin());

      match /poll_votes/{voteId} {
        allow read: if signedIn();
        allow create: if signedIn() && voteId == uid();
        allow update: if false;
        allow delete: if false;
      }
    }

    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /saves/{saveId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /hidden_posts/{hiddenId} {
      allow read: if signedIn() && resource.data.user_id == uid();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && (resource.data.user_id == uid() || isCounterUpdate());
      allow delete: if signedIn() && (resource.data.user_id == uid() || isAdmin());
    }

    match /comment_likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /reposts/{repostId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.owner_id == uid();
      allow update: if signedIn() && (resource.data.owner_id == uid() || isAdmin());
      allow delete: if signedIn() && (resource.data.owner_id == uid() || isAdmin());
    }

    match /community_members/{memberId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /community_moderators/{modId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /community_rules/{ruleId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if signedIn();
    }

    match /user_settings/{userId} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId);
    }

    // ✅ ADDED: was missing — onboarding writes here, silently failed in production
    match /user_interests/{userId} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId);
    }

    match /stories/{storyId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.user_id == uid();
      allow delete: if signedIn() && (resource.data.user_id == uid() || isAdmin());
    }

    match /story_views/{viewId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /story_seen/{seenId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    match /story_comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      // ✅ ADDED: edit/delete own story comments
      allow update: if signedIn() && resource.data.user_id == uid();
      allow delete: if signedIn() && (resource.data.user_id == uid() || isAdmin());
    }

    match /conversations/{convoId} {
      allow get: if signedIn() && uid() in resource.data.participant_ids;
      allow list: if signedIn();
      allow create: if signedIn() && uid() in request.resource.data.participant_ids;
      allow update: if signedIn() && uid() in resource.data.participant_ids;
      allow delete: if signedIn() && uid() in resource.data.participant_ids;

      match /messages/{messageId} {
        allow read: if signedIn() &&
          uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participant_ids;
        allow create: if signedIn() &&
          uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participant_ids &&
          request.resource.data.sender_id == uid();
        allow update: if signedIn() && resource.data.sender_id == uid();
        allow delete: if signedIn() && resource.data.sender_id == uid();
      }

      match /participants/{participantId} {
        allow read: if signedIn() &&
          uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participant_ids;
        allow create: if signedIn();
        allow update: if signedIn() && (
          participantId == uid() ||
          uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participant_ids
        );
        allow delete: if signedIn() && participantId == uid();
      }

      match /typing/{typingUserId} {
        allow read: if signedIn() &&
          uid() in get(/databases/$(database)/documents/conversations/$(convoId)).data.participant_ids;
        allow write: if signedIn() && typingUserId == uid();
      }
    }

    match /conversation_participants/{participantId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.user_id == uid();
      allow delete: if signedIn() && resource.data.user_id == uid();
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.sender_id == uid();
      allow update: if signedIn() && resource.data.sender_id == uid();
      allow delete: if signedIn() && resource.data.sender_id == uid();
    }

    match /boosts/{boostId} {
      allow create: if signedIn()
        && request.resource.data.user_id == uid()
        && request.resource.data.status == "active";
      allow read: if signedIn() && (resource.data.user_id == uid() || isAdmin());
      allow update, delete: if false;
    }

    match /account_deletion_requests/{userId} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId);
    }

    match /data_export_requests/{userId} {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId);
    }

    match /blocks/{blockId} {
      allow read: if signedIn() && (resource.data.blocker_id == uid() || resource.data.blocked_id == uid());
      allow create: if signedIn() && request.resource.data.blocker_id == uid();
      allow delete: if signedIn() && resource.data.blocker_id == uid();
    }

    match /user_blocks/{blockId} {
      allow read: if signedIn() && (resource.data.blocker_id == uid() || resource.data.blocked_id == uid());
      allow create: if signedIn() && request.resource.data.blocker_id == uid();
      allow delete: if signedIn() && resource.data.blocker_id == uid();
    }

    match /polls/{pollId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();

      match /votes/{voteId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.user_id == uid();
        allow update: if signedIn() && resource.data.user_id == uid();
        allow delete: if signedIn() && resource.data.user_id == uid();
      }
    }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && (resource.data.creator_id == uid() || isAdmin());
      allow delete: if signedIn() && (resource.data.creator_id == uid() || isAdmin());
    }

    match /hashtags/{hashtagId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /hashtag_counts/{hashtagId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /support_reports/{reportId} {
      allow create: if signedIn() && request.resource.data.user_id == uid();
      allow read: if signedIn() && (resource.data.user_id == uid() || isAdmin());
    }

    match /post_views/{viewId} {
      allow read: if signedIn();
      allow write: if signedIn();
    }

    // ✅ ADDED: Cloud Function writes here; client reads only own doc
    match /parental_verifications/{userId} {
      allow read: if isSelf(userId);
      allow write: if false; // Cloud Function only (admin SDK)
    }

    match /app_config/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
