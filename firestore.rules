rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================================================
       HELPER FUNCTIONS
    ========================================================= */
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isSelf(userId) {
      return signedIn() && uid() == userId;
    }

    // Matches the "profiles" collection in your TypeScript code
    function profileDoc(userId) {
      return get(/databases/$(database)/documents/profiles/$(userId));
    }

    function hasProfile(userId) {
      return exists(/databases/$(database)/documents/profiles/$(userId));
    }

    function isAdmin() {
      return signedIn() &&
        hasProfile(uid()) &&
        profileDoc(uid()).data.role == "admin";
    }

    function isSuspended() {
      return signedIn() &&
        hasProfile(uid()) &&
        profileDoc(uid()).data.suspended == true;
    }

    function isPrivate(userId) {
      return hasProfile(userId) &&
        profileDoc(userId).data.is_private == true;
    }

    /* =========================================================
       PROFILES (Matches "profiles" in code)
    ========================================================= */
    match /profiles/{userId} {
      allow read: if (!isPrivate(userId)) || isSelf(userId) || isAdmin();
      allow create: if isSelf(userId); // Fixed: creation allowed
      allow update: if isSelf(userId) && !isSuspended();
      allow delete: if isSelf(userId) || isAdmin();
    }

    /* =========================================================
       FOLLOWS (Matches "follows" in code)
    ========================================================= */
    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && !isSuspended() && request.resource.data.follower_id == uid();
      allow delete: if signedIn() && !isSuspended() && resource.data.follower_id == uid();
    }

    /* =========================================================
       NOTIFICATIONS (Matches "notifications" in code)
    ========================================================= */
    match /notifications/{notifId} {
      allow read: if signedIn() && resource.data.receiver_id == uid();
      allow create: if signedIn() && !isSuspended(); // Functions create this
    }

    /* =========================================================
       FALLBACK
    ========================================================= */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}