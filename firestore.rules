rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function communityDoc(communityId) {
      return get(/databases/$(database)/documents/communities/$(communityId));
    }

    function isCommunityOwner(communityId) {
      return signedIn() && communityDoc(communityId).data.owner_id == request.auth.uid;
    }


    match /profiles/{userId} {
      allow read: if signedIn();
      allow create, update, delete: if isSelf(userId);
    }

    match /user_settings/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /user_interests/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /conversations/{conversationId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn();
      allow delete: if false;
    }

    match /conversation_participants/{participantId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow delete: if signedIn();
      allow update: if false;
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.sender_id == request.auth.uid;
      allow update: if signedIn() && resource.data.sender_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.sender_id == request.auth.uid;
    }

    match /communities/{communityId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.owner_id == request.auth.uid;
      allow update: if isCommunityOwner(communityId);
      allow delete: if false;
    }

    match /community_members/{memberId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn() && (
        resource.data.user_id == request.auth.uid ||
        isCommunityOwner(resource.data.community_id)
      );
    }

    match /community_moderators/{docId} {
      allow read: if signedIn();
      allow write: if signedIn() && isCommunityOwner(request.resource.data.community_id);
      allow delete: if signedIn() && isCommunityOwner(resource.data.community_id);
    }

    match /community_rules/{ruleId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && isCommunityOwner(request.resource.data.community_id);
      allow delete: if signedIn() && isCommunityOwner(resource.data.community_id);
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.user_id == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() && resource.data.author_id == request.auth.uid;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.follower_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.follower_id == request.auth.uid;
      allow update: if false;
    }

    match /notifications/{id} {
      allow read: if signedIn() && (
        resource.data.receiver_id == request.auth.uid ||
        resource.data.user_id == request.auth.uid
      );
      allow create: if signedIn();
      allow update, delete: if signedIn() && (
        resource.data.receiver_id == request.auth.uid ||
        resource.data.user_id == request.auth.uid
      );
    }

    match /user_blocks/{id} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.blocker_id == request.auth.uid;
      allow delete: if signedIn() && resource.data.blocker_id == request.auth.uid;
      allow update: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
